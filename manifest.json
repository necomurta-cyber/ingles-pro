S.xp = S.xp||0; S.streak = S.streak||0; S.streakBest = S.streakBest||0;
S.lastDate = S.lastDate||''; S.fcDone = S.fcDone||0; S.exDone = S.exDone||0;
S.chatDone = S.chatDone||0; S.dlgDone = S.dlgDone||0; S.dailyDate = S.dailyDate||'';
S.totalEx = S.totalEx||0; S.totalCorrect = S.totalCorrect||0; S.errors = S.errors||[];
function save(){ try { localStorage.setItem('re_v20', JSON.stringify(S)); } catch(e) {} }
function todayStr(){ return new Date().toISOString().slice(0,10); }
function checkDay(){
var t = todayStr();
if (S.dailyDate !== t) {
var y = new Date(); y.setDate(y.getDate()-1);
if (S.lastDate === y.toISOString().slice(0,10)) S.streak++;
else if (S.lastDate !== t) S.streak = 1;
if (S.streak > S.streakBest) S.streakBest = S.streak;
S.lastDate = t; S.fcDone = 0; S.exDone = 0; S.chatDone = 0; S.dailyDate = t; save();
}
}
function getLv(){
for (var i = LEVELS.length-1; i >= 0; i--) if (S.xp >= LEVELS[i].xpReq) return LEVELS[i];
