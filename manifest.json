<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0,maximum-scale=1.0">
<title>Renato's English</title>
<link rel="manifest" href="manifest.json">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-title" content="REnglish">
<meta name="theme-color" content="#080c14">
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Bebas+Neue&display=swap" rel="stylesheet">
<style>
:root{
--bg:#080c14;--bg2:#0e1420;--bg3:#161d2e;
--bd:#1e2a40;--bd2:#253347;
--ac:#3b82f6;--ac2:#8b5cf6;--ac3:#06b6d4;
--gr:#10b981;--ye:#f59e0b;--re:#ef4444;--or:#f97316;
--tx:#e2e8f0;--tx2:#94a3b8;--tx3:#64748b;
--r:14px;--r2:20px;--r3:28px;
}
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent}
html{height:100%}
body{background:var(--bg);color:var(--tx);font-family:'Space Grotesk',sans-serif;min-height:100vh;overflow-x:hidden;max-width:480px;margin:0 auto}
/* HEADER */
.hdr{position:sticky;top:0;z-index:50;background:var(--bg)ee;backdrop-filter:blur(16px);border-bottom:1px solid var(--bd);padding:10px 16px;display:flex;align-items:center;justify-content:space-between}
.logo{font-family:'Bebas Neue',sans-serif;font-size:1.3rem;letter-spacing:.05em;color:var(--tx)}
.logo span{color:var(--ac)}
.badges{display:flex;gap:6px}
.badge{padding:4px 10px;border-radius:20px;font-size:.72rem;font-weight:600}
.badge-lv{background:var(--ye)20;color:var(--ye);border:1px solid var(--ye)40}
.badge-xp{background:var(--ac)20;color:var(--ac);border:1px solid var(--ac)40}
/* NAV */
.nav{display:flex;gap:2px;padding:8px 10px;overflow-x:auto;scrollbar-width:none;background:var(--bg2);border-bottom:1px solid var(--bd)}
.nav::-webkit-scrollbar{display:none}
.ntab{flex-shrink:0;padding:7px 12px;border-radius:10px;font-size:.78rem;font-weight:600;cursor:pointer;border:none;background:transparent;color:var(--tx3);transition:all .2s;display:flex;align-items:center;gap:5px}
.ntab.on{background:var(--ac)15;color:var(--ac);border:1px solid var(--ac)30}
/* MAIN */
main{padding:14px;min-height:calc(100vh - 100px)}
.pg{display:none}.pg.on{display:block;animation:fadeUp .25s ease}
@keyframes fadeUp{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:none}}
/* CARDS */
.card{background:var(--bg2);border:1px solid var(--bd);border-radius:var(--r2);padding:16px;margin-bottom:12px}
.card-accent{background:linear-gradient(135deg,var(--bg2),var(--bg3));border:1px solid var(--bd2)}
.sec-title{font-family:'Bebas Neue',sans-serif;font-size:1.1rem;letter-spacing:.05em;color:var(--tx2);margin-bottom:14px}
/* BAR */
.bar{height:6px;background:var(--bg3);border-radius:3px;overflow:hidden}
.bar-fill{height:100%;border-radius:3px;transition:width .6s cubic-bezier(.34,1.56,.64,1)}
.bar-blue{background:linear-gradient(90deg,var(--ac),var(--ac2))}
.bar-green{background:linear-gradient(90deg,var(--gr),var(--ac3))}
.bar-gold{background:linear-gradient(90deg,var(--ye),var(--or))}
/* HOME */
.hero{background:linear-gradient(135deg,#0a1628 0%,#111827 50%,#0a0e1a 100%);border:1px solid var(--bd2);border-radius:var(--r3);padding:22px 18px;margin-bottom:14px;position:relative;overflow:hidden}
.hero::before{content:'';position:absolute;top:-40px;right:-40px;width:160px;height:160px;background:var(--ac)08;border-radius:50%;pointer-events:none}
.hero-greeting{font-size:.8rem;color:var(--tx3);margin-bottom:4px}
.hero-name{font-family:'Bebas Neue',sans-serif;font-size:2rem;letter-spacing:.04em;line-height:1}
.hero-name span{color:var(--ac)}
.hero-sub{font-size:.82rem;color:var(--tx2);margin-top:6px;line-height:1.5}
.lv-row{display:flex;justify-content:space-between;align-items:center;font-size:.74rem;margin-top:14px;margin-bottom:6px}
.lv-name{color:var(--ye);font-weight:700}
.lv-xp{color:var(--tx3)}
.stats-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:14px}
.stat-box{background:var(--bg2);border:1px solid var(--bd);border-radius:var(--r);padding:12px 8px;text-align:center}
.stat-num{font-family:'Bebas Neue',sans-serif;font-size:1.6rem;color:var(--ac)}
.stat-lbl{font-size:.65rem;color:var(--tx3);margin-top:2px}
.daily-card{background:linear-gradient(135deg,#0a1a2e,#091520);border:1px solid var(--ac3)20;border-radius:var(--r2);padding:14px;margin-bottom:14px}
.daily-row{display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;font-size:.8rem}
.daily-t{color:var(--ac3);font-weight:700}
.daily-pct{color:var(--tx3)}
.daily-tasks{display:flex;gap:6px;flex-wrap:wrap;margin-top:10px}
.dtask{font-size:.72rem;padding:4px 10px;border-radius:20px;background:var(--bg3);border:1px solid var(--bd);color:var(--tx3)}
.dtask.done{background:var(--gr)15;border-color:var(--gr)40;color:var(--gr)}
.streak-card{background:linear-gradient(135deg,#1a1000,#0a0800);border:1px solid var(--ye)20;border-radius:var(--r2);padding:14px;margin-bottom:14px;display:flex;align-items:center;gap:14px}
.module-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:14px}
.mod-btn{background:var(--bg2);border:1px solid var(--bd);border-radius:var(--r2);padding:14px;cursor:pointer;text-align:left;color:var(--tx);transition:all .2s;position:relative;overflow:hidden}
.mod-btn:hover{border-color:var(--ac)50;transform:translateY(-1px)}
.mod-btn::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,var(--ac)05,transparent);pointer-events:none}
.mod-icon{font-size:1.4rem;margin-bottom:6px;display:block}
.mod-name{font-size:.85rem;font-weight:700}
.mod-sub{font-size:.7rem;color:var(--tx3);margin-top:2px}
.mod-prog{margin-top:8px}
/* EXERCISE SYSTEM */
.ex-wrap{min-height:calc(100vh - 120px);display:flex;flex-direction:column}
.ex-header{padding:12px 14px;border-bottom:1px solid var(--bd);display:flex;align-items:center;gap:10px}
.ex-close{background:none;border:none;color:var(--tx3);font-size:1.1rem;cursor:pointer;padding:4px}
.ex-progbar{flex:1;height:8px;background:var(--bg3);border-radius:4px;overflow:hidden}
.ex-progfill{height:100%;background:linear-gradient(90deg,var(--ac),var(--ac2));border-radius:4px;transition:width .4s ease}
.ex-count{font-size:.78rem;color:var(--tx3);white-space:nowrap}
.ex-body{flex:1;padding:16px;display:flex;flex-direction:column}
.ex-type-badge{display:inline-flex;align-items:center;gap:6px;padding:4px 12px;border-radius:20px;font-size:.72rem;font-weight:700;margin-bottom:16px;border:1px solid}
.ex-question{font-size:1.05rem;font-weight:600;margin-bottom:6px;line-height:1.4}
.ex-hint{font-size:.8rem;color:var(--tx3);margin-bottom:20px}
/* EXERCISE TYPES */
/* 1. Audio Match */
.audio-choices{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:16px}
.audio-btn{padding:14px;border-radius:var(--r);border:2px solid var(--bd);background:var(--bg2);cursor:pointer;text-align:center;font-size:.9rem;font-weight:600;color:var(--tx);transition:all .2s}
.audio-btn:hover{border-color:var(--ac)50;background:var(--ac)08}
.audio-btn.correct{background:var(--gr)15;border-color:var(--gr);color:var(--gr)}
.audio-btn.wrong{background:var(--re)15;border-color:var(--re);color:var(--re)}
.audio-btn.locked{cursor:default}
/* 2. Build Sentence */
.sentence-area{min-height:60px;border:2px dashed var(--bd2);border-radius:var(--r);padding:12px;margin-bottom:14px;display:flex;flex-wrap:wrap;gap:6px;align-content:flex-start;cursor:pointer}
.sentence-area:empty::after{content:'Toque nas palavras para montar a frase';color:var(--tx3);font-size:.82rem}
.word-chip{padding:6px 12px;border-radius:20px;font-size:.85rem;font-weight:600;cursor:pointer;transition:all .2s;border:1px solid;user-select:none}
.word-chip.source{background:var(--bg3);border-color:var(--bd2);color:var(--tx)}
.word-chip.source:hover{border-color:var(--ac)50;background:var(--ac)10}
.word-chip.placed{background:var(--ac)20;border-color:var(--ac)60;color:var(--ac)}
.word-chip.placed:hover{background:var(--re)15;border-color:var(--re)50}
.word-bank{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:16px}
/* 3. Listen & Type */
.listen-area{background:var(--bg3);border:1px solid var(--bd);border-radius:var(--r2);padding:20px;margin-bottom:16px;text-align:center}
.listen-hint{font-size:.78rem;color:var(--tx3);margin-top:8px}
.type-input{width:100%;background:var(--bg2);border:2px solid var(--bd2);border-radius:var(--r);padding:12px 14px;color:var(--tx);font-family:'Space Grotesk',sans-serif;font-size:.95rem;outline:none;margin-bottom:14px;transition:border-color .2s}
.type-input:focus{border-color:var(--ac)60}
.type-input.ok{border-color:var(--gr);background:var(--gr)08}
.type-input.ng{border-color:var(--re);background:var(--re)08}
/* 4. Match Pairs */
.pairs-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:16px}
.pair-btn{padding:12px 10px;border-radius:var(--r);border:2px solid var(--bd);background:var(--bg2);cursor:pointer;text-align:center;font-size:.82rem;font-weight:600;color:var(--tx);transition:all .2s;min-height:52px;display:flex;align-items:center;justify-content:center}
.pair-btn:hover{border-color:var(--ac)50}
.pair-btn.selected{border-color:var(--ac);background:var(--ac)15;color:var(--ac)}
.pair-btn.matched{border-color:var(--gr);background:var(--gr)15;color:var(--gr);cursor:default}
.pair-btn.wrong-flash{border-color:var(--re);background:var(--re)15;animation:shake .3s ease}
@keyframes shake{0%,100%{transform:translateX(0)}25%{transform:translateX(-4px)}75%{transform:translateX(4px)}}
/* 5. Repeat Phrase */
.repeat-box{background:var(--bg3);border:1px solid var(--bd2);border-radius:var(--r2);padding:20px;margin-bottom:20px;text-align:center}
.repeat-phrase{font-size:1.1rem;font-weight:700;line-height:1.5;margin:12px 0}
.repeat-trans{font-size:.82rem;color:var(--tx3);margin-top:6px}
.mic-btn-large{width:72px;height:72px;border-radius:50%;border:none;background:linear-gradient(135deg,var(--ac),var(--ac2));cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:1.6rem;margin:0 auto;box-shadow:0 4px 20px var(--ac)40;transition:all .2s}
.mic-btn-large.rec{background:linear-gradient(135deg,var(--re),#dc2626);animation:pulse-mic 1s ease infinite;box-shadow:0 4px 20px var(--re)40}
.mic-btn-large:hover{transform:scale(1.05)}
@keyframes pulse-mic{0%,100%{transform:scale(1)}50%{transform:scale(1.08)}}
.mic-status{font-size:.78rem;color:var(--tx3);text-align:center;margin-top:8px}
/* FEEDBACK BAR */
.feedback-bar{position:fixed;bottom:0;left:0;right:0;max-width:480px;margin:0 auto;padding:14px 16px;border-top:2px solid;transition:all .3s;z-index:100}
.feedback-bar.ok{background:#0a2010;border-color:var(--gr);color:var(--gr)}
.feedback-bar.ng{background:#200a0a;border-color:var(--re);color:var(--re)}
.fb-title{font-weight:700;font-size:.95rem;margin-bottom:2px}
.fb-text{font-size:.82rem;opacity:.8}
.fb-btn{float:right;padding:8px 18px;border-radius:10px;border:none;font-family:'Space Grotesk',sans-serif;font-size:.85rem;font-weight:700;cursor:pointer;margin-top:-4px}
.feedback-bar.ok .fb-btn{background:var(--gr);color:#fff}
.feedback-bar.ng .fb-btn{background:var(--re);color:#fff}
/* PLAY BTN */
.play-btn{display:inline-flex;align-items:center;gap:8px;padding:10px 18px;border-radius:12px;border:none;background:var(--ac)20;border:1px solid var(--ac)40;color:var(--ac);font-family:'Space Grotesk',sans-serif;font-size:.88rem;font-weight:700;cursor:pointer;transition:all .2s}
.play-btn:hover{background:var(--ac)30}
.play-btn.go{animation:pulse 1s ease infinite;background:var(--ac)30}
.play-btn-slow{background:var(--ac2)20;border-color:var(--ac2)40;color:var(--ac2)}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.6}}
/* SUBMIT BTN */
.submit-btn{width:100%;padding:14px;border-radius:var(--r2);border:none;font-family:'Space Grotesk',sans-serif;font-size:.95rem;font-weight:700;cursor:pointer;margin-top:auto;transition:all .2s}
.submit-btn.active{background:linear-gradient(135deg,var(--ac),var(--ac2));color:#fff;box-shadow:0 4px 16px var(--ac)30}
.submit-btn.inactive{background:var(--bg3);color:var(--tx3);cursor:not-allowed}
/* RESULTS */
.result-screen{text-align:center;padding:24px 16px;display:flex;flex-direction:column;align-items:center;gap:12px}
.result-emoji{font-size:3rem}
.result-score{font-family:'Bebas Neue',sans-serif;font-size:3.5rem;color:var(--ac)}
.result-label{font-size:.9rem;color:var(--tx2)}
.result-xp{font-size:1rem;color:var(--ye);font-weight:700;background:var(--ye)15;padding:8px 20px;border-radius:20px;border:1px solid var(--ye)30}
.result-btns{display:flex;gap:10px;margin-top:10px}
.rbtn{padding:11px 20px;border-radius:12px;border:1px solid var(--bd);background:var(--bg2);color:var(--tx);font-family:'Space Grotesk',sans-serif;font-size:.88rem;font-weight:600;cursor:pointer}
.rbtn.primary{background:var(--ac);border-color:var(--ac);color:#fff}
/* FLASHCARDS */
.fc-wrap{perspective:1000px;margin-bottom:14px}
.fc{width:100%;height:220px;position:relative;transform-style:preserve-3d;transition:transform .5s;cursor:pointer}
.fc.flip{transform:rotateY(180deg)}
.fc-f,.fc-b{position:absolute;inset:0;border-radius:var(--r2);backface-visibility:hidden;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:20px;text-align:center}
.fc-f{background:var(--bg2);border:1px solid var(--bd2)}
.fc-b{transform:rotateY(180deg);background:linear-gradient(135deg,#0a1628,#0d1520);border:1px solid var(--bd2)}
.fc-lbl{font-size:.65rem;color:var(--tx3);text-transform:uppercase;letter-spacing:.1em;margin-bottom:8px}
.fc-word{font-family:'Bebas Neue',sans-serif;font-size:2rem;letter-spacing:.05em;margin:4px 0}
.fc-ph{font-size:.78rem;color:var(--ac);margin-top:2px}
.fc-trans{font-family:'Bebas Neue',sans-serif;font-size:1.5rem;color:var(--gr);letter-spacing:.04em}
.fc-ex{font-size:.78rem;color:var(--tx3);margin-top:8px;font-style:italic;line-height:1.4}
.fc-controls{display:flex;gap:8px;margin-top:10px}
.fc-btn{flex:1;padding:11px;border-radius:12px;border:none;font-family:'Space Grotesk',sans-serif;font-size:.82rem;font-weight:700;cursor:pointer}
.fc-btn.wrong{background:var(--re)20;color:var(--re);border:1px solid var(--re)40}
.fc-btn.skip{background:var(--bg3);color:var(--tx3);border:1px solid var(--bd);flex:.5}
.fc-btn.correct{background:var(--gr)20;color:var(--gr);border:1px solid var(--gr)40}
.fc-audio{display:flex;gap:8px;justify-content:center;margin-top:10px}
.fc-tip{font-size:.72rem;color:var(--tx3);text-align:center;margin-top:6px}
/* VOCAB */
.search-input{width:100%;background:var(--bg2);border:1px solid var(--bd2);border-radius:12px;padding:10px 14px;color:var(--tx);font-family:'Space Grotesk',sans-serif;font-size:.88rem;outline:none;margin-bottom:12px}
.search-input:focus{border-color:var(--ac)50}
.search-input::placeholder{color:var(--tx3)}
.pills{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:14px}
.pill{padding:5px 12px;border-radius:20px;font-size:.74rem;font-weight:600;cursor:pointer;border:1px solid var(--bd);background:var(--bg2);color:var(--tx3);transition:all .2s}
.pill.on{background:var(--ac)20;color:var(--ac);border-color:var(--ac)50}
.vitem{background:var(--bg2);border:1px solid var(--bd);border-radius:var(--r);padding:12px 14px;display:flex;gap:10px;align-items:flex-start;margin-bottom:8px}
.vitem.locked{opacity:.35}
.vitem-left{flex:1}
.vitem-en{font-weight:700;font-size:.9rem}
.vitem-ph{font-size:.72rem;color:var(--ac);margin-top:2px}
.vitem-pt{font-size:.82rem;color:var(--tx2);margin-top:3px}
.vitem-cat{font-size:.65rem;padding:2px 8px;border-radius:10px;background:var(--bg3);color:var(--ac3);border:1px solid var(--bd);white-space:nowrap;margin-top:4px;display:inline-block}
.vitem-right{display:flex;flex-direction:column;gap:5px;align-items:flex-end;flex-shrink:0}
/* CHAT */
.chat-wrap{background:var(--bg2);border:1px solid var(--bd);border-radius:var(--r2);overflow:hidden;margin-bottom:12px}
.chat-head{background:var(--bg3);padding:12px 14px;border-bottom:1px solid var(--bd);display:flex;align-items:center;justify-content:space-between}
.chat-av{width:34px;height:34px;border-radius:50%;background:linear-gradient(135deg,var(--ac),var(--ac2));display:flex;align-items:center;justify-content:center;font-size:.9rem;flex-shrink:0}
.chat-name{font-weight:700;font-size:.88rem}
.chat-status{font-size:.7rem;color:var(--gr)}
.voice-toggle{background:none;border:1px solid var(--bd);border-radius:8px;padding:5px 10px;cursor:pointer;color:var(--tx3);font-family:'Space Grotesk',sans-serif;font-size:.73rem;font-weight:600}
.voice-toggle.on{border-color:var(--gr)50;color:var(--gr);background:var(--gr)10}
.msgs{height:340px;overflow-y:auto;padding:12px;display:flex;flex-direction:column;gap:8px;scrollbar-width:thin}
.msg{max-width:88%}
.msg.ai{align-self:flex-start}
.msg.me{align-self:flex-end}
.msg-bubble{padding:9px 13px;border-radius:16px;font-size:.85rem;line-height:1.5}
.msg.ai .msg-bubble{background:var(--bg3);border:1px solid var(--bd);border-bottom-left-radius:4px}
.msg.me .msg-bubble{background:linear-gradient(135deg,var(--ac),#2563eb);border-bottom-right-radius:4px}
.msg-corr{font-size:.72rem;color:var(--ye);margin-top:4px;padding:5px 9px;background:var(--ye)08;border-radius:8px;border-left:2px solid var(--ye)}
.chat-input-row{padding:10px;border-top:1px solid var(--bd);display:flex;gap:7px;align-items:flex-end}
.chat-input{flex:1;background:var(--bg3);border:1px solid var(--bd2);border-radius:10px;padding:9px 12px;color:var(--tx);font-family:'Space Grotesk',sans-serif;font-size:.85rem;resize:none;outline:none}
.chat-input:focus{border-color:var(--ac)50}
.chat-input::placeholder{color:var(--tx3)}
.send-btn{background:var(--ac);border:none;border-radius:10px;padding:9px 13px;cursor:pointer;color:#fff;font-size:.95rem;flex-shrink:0}
.send-btn:disabled{opacity:.4;cursor:not-allowed}
.mic-chat{background:var(--bg3);border:1px solid var(--bd);border-radius:10px;padding:9px 12px;cursor:pointer;color:var(--tx3);font-size:.9rem;flex-shrink:0}
.mic-chat.rec{background:var(--re)20;border-color:var(--re)50;color:var(--re);animation:pulse 1s ease infinite}
.topic-chips{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:10px}
.topic-chip{padding:5px 11px;border-radius:20px;font-size:.73rem;font-weight:600;border:1px solid var(--bd);background:var(--bg2);color:var(--tx3);cursor:pointer;transition:all .2s}
.topic-chip:hover{border-color:var(--ac)50;color:var(--tx)}
.dots-wrap{display:flex;gap:4px;align-items:center;padding:3px 0}
.dot{width:5px;height:5px;border-radius:50%;background:var(--tx3);animation:bounce .8s ease infinite}
.dot:nth-child(2){animation-delay:.15s}.dot:nth-child(3){animation-delay:.3s}
@keyframes bounce{0%,60%,100%{transform:translateY(0)}30%{transform:translateY(-5px)}}
/* LEVELS PAGE */
.lv-list{display:grid;gap:10px}
.lv-item{background:var(--bg2);border:1px solid var(--bd);border-radius:var(--r2);padding:16px;display:flex;gap:14px;align-items:center}
.lv-item.current{border-color:var(--ye)40;background:linear-gradient(135deg,var(--bg2),#0f0e00)}
.lv-item.locked{opacity:.45}
.lv-icon-big{font-size:1.8rem;flex-shrink:0}
.lv-info{flex:1}
.lv-title{font-weight:700;font-size:.92rem}
.lv-reqs{font-size:.73rem;color:var(--tx3);margin-top:3px}
.lv-desc{font-size:.78rem;color:var(--tx);margin-top:5px;line-height:1.4}
.lv-badge{margin-left:auto;font-size:.7rem;padding:4px 10px;border-radius:20px;font-weight:700;flex-shrink:0}
.lv-badge.done{background:var(--gr)20;color:var(--gr);border:1px solid var(--gr)40}
.lv-badge.curr{background:var(--ye)20;color:var(--ye);border:1px solid var(--ye)40}
.lv-badge.lock{background:var(--bg3);color:var(--tx3);border:1px solid var(--bd)}
/* MODULE SELECT */
.mod-select{display:grid;gap:10px}
.mod-card{background:var(--bg2);border:1px solid var(--bd);border-radius:var(--r2);padding:16px;cursor:pointer;transition:all .2s;position:relative;overflow:hidden}
.mod-card:hover{border-color:var(--ac)50;transform:translateY(-2px)}
.mod-card.locked{opacity:.5;cursor:not-allowed}
.mod-card::after{content:'';position:absolute;top:0;right:0;width:60px;height:60px;background:var(--ac)05;border-radius:50%;transform:translate(20px,-20px)}
.mod-card-icon{font-size:1.6rem;margin-bottom:8px}
.mod-card-name{font-weight:700;font-size:.95rem}
.mod-card-desc{font-size:.78rem;color:var(--tx3);margin-top:4px}
.mod-card-stats{display:flex;gap:8px;margin-top:8px;font-size:.72rem;color:var(--tx3)}
.mod-stat{background:var(--bg3);padding:2px 8px;border-radius:10px;border:1px solid var(--bd)}
.ex-type-select{display:grid;grid-template-columns:1fr 1fr;gap:8px}
.ex-type-card{background:var(--bg2);border:1px solid var(--bd);border-radius:var(--r);padding:12px;cursor:pointer;text-align:center;transition:all .2s}
.ex-type-card:hover{border-color:var(--ac)50}
.ex-type-card.locked{opacity:.4;cursor:not-allowed}
.ex-type-icon{font-size:1.4rem;margin-bottom:4px}
.ex-type-name{font-size:.78rem;font-weight:600}
/* UTIL */
.flex-center{display:flex;align-items:center;justify-content:center}
.gap-8{gap:8px}
.mt-8{margin-top:8px}
.lv-up-modal{position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);z-index:200;background:linear-gradient(135deg,#0a1628,#0a0800);border:2px solid var(--ye);border-radius:var(--r3);padding:28px 24px;text-align:center;max-width:300px;width:90%}
.lv-up-icon{font-size:2.5rem;margin-bottom:8px}
.lv-up-title{font-family:'Bebas Neue',sans-serif;font-size:1.6rem;color:var(--ye);letter-spacing:.05em}
.lv-up-btn{margin-top:16px;padding:10px 24px;background:var(--ac);border:none;border-radius:12px;color:#fff;font-family:'Space Grotesk',sans-serif;font-size:.9rem;font-weight:700;cursor:pointer}
</style>
</head>
