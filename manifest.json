var curModuleId = null, exQueue = [], exIdx = 0, exScore = 0, exTotal = 0;
var curExType = null;
var EX_TYPES = [
{id:'audio_match', name:'Combine o Áudio', icon:'🔊', desc:'Ouça e escolha a palavra'},
{id:'build_sentence', name:'Monte a Frase', icon:'📝', desc:'Organize as palavras'},
{id:'listen_type', name:'Escuta & Escreve', icon:'👂', desc:'Ouça e escreva'},
