var TTS = 'speechSynthesis' in window;
var voices = [], voiceOn = true, activBtn = null;
if (TTS) {
window.speechSynthesis.onvoiceschanged = function(){ voices = window.speechSynthesis.getVoices(); };
voices = window.speechSynthesis.getVoices();
}
function bestVoice(){
var prefs = ['Google US English','Samantha','Karen','Microsoft Zira'];
for (var i = 0; i < prefs.length; i++) {
var v = voices.find(function(v){ return v.name.indexOf(prefs[i]) >= 0; });
if (v) return v;
}
return voices.find(function(v){ return v.lang && v.lang.startsWith('en'); }) || null;
}
function speak(text, btn, rate){
if (!TTS || !text) return;
window.speechSynthesis.cancel();
if (activBtn) activBtn.classList.remove('go');
activBtn = btn; if (btn) btn.classList.add('go');
var u = new SpeechSynthesisUtterance(text.trim());
u.lang = 'en-US'; u.rate = rate || 0.85;
var v = bestVoice(); if (v) u.voice = v;
u.onend = u.onerror = function(){ if (btn) btn.classList.remove('go'); activBtn = null; };
window.speechSynthesis.speak(u);
}
function stopSpeak(){
if (TTS) window.speechSynthesis.cancel();
if (activBtn) activBtn.classList.remove('go');
activBtn = null;
}
