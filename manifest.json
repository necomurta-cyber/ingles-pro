// ── EX 4: MATCH PAIRS ──────────────────────────────────────
function buildMatchPairs(item, isWord){
var pool = isWord ? WORDS.filter(function(x){ return x.lv <= unlocked() && x.id !== item.id; }) : ALL_SENTENCES.filter(function(x){ return x.lv <= unlocked() && x.id !== item.id; });
var selected = [item].concat(pool.sort(function(){ return Math.random()-.5; }).slice(0,4));
// Left side always EN, right side always PT — shuffled independently
var lefts = selected.map(function(x){ return {id:x.id, text:x.en}; }).sort(function(){ return Math.random()-.5; });
var rights = selected.map(function(x){ return {id:x.id, text:x.pt}; }).sort(function(){ return Math.random()-.5; });
var matched = [], selLeft = null, selRight = null;
var el = document.getElementById('exercise');
el.innerHTML = exHdr() +
'<div class="ex-body">' +
'<div class="ex-type-badge" style="color:#8b5cf6;border-color:#8b5cf640;background:#8b5cf610">🔗 Combine os Pares</div>' +
'<div class="ex-question">Conecte inglês com português:</div>' +
'<div style="display:grid;grid-template-columns:1fr 1fr;gap:4px;margin-bottom:8px">' +
'<div style="text-align:center;font-size:.72rem;font-weight:700;color:#3b82f6;padding:6px;background:#3b82f610;border-radius:8px">🇺🇸 INGLÊS</div>' +
'<div style="text-align:center;font-size:.72rem;font-weight:700;color:#10b981;padding:6px;background:#10b98110;border-radius:8px">🇧🇷 PORTUGUÊS</div>' +
'</div>' +
'<div class="pairs-grid" id="pairsGrid"></div>' +
'</div>';
attachClose();
var grid = document.getElementById('pairsGrid');
function makePairBtn(id, text, side){
var btn = document.createElement('button');
btn.className = 'pair-btn';
btn.id = (side==='left'?'pl_':'pr_') + id;
btn.textContent = text;
btn.addEventListener('click', function(){
if (matched.indexOf(id) >= 0) return;
document.querySelectorAll('.pair-btn').forEach(function(b){ b.classList.remove('wrong-flash'); });
if (side === 'left'){
if (selLeft) { var pl = document.getElementById('pl_'+selLeft); if(pl) pl.classList.remove('selected'); }
selLeft = id; btn.classList.add('selected');
} else {
if (selRight) { var pr = document.getElementById('pr_'+selRight); if(pr) pr.classList.remove('selected'); }
selRight = id; btn.classList.add('selected');
}
if (selLeft && selRight){
if (selLeft === selRight){
matched.push(selLeft);
var pl2 = document.getElementById('pl_'+selLeft);
var pr2 = document.getElementById('pr_'+selRight);
if(pl2) pl2.classList.add('matched');
if(pr2) pr2.classList.add('matched');
speak(lefts.find(function(l){ return l.id===selLeft; }).text, null);
S.totalCorrect++; selLeft = null; selRight = null;
if (matched.length === selected.length){
setTimeout(function(){ exIdx++; exScore++; S.exDone++; S.totalEx += selected.length; save(); addXP(10); runNext(); }, 700);
}
} else {
var lBtn = document.getElementById('pl_'+selLeft);
var rBtn = document.getElementById('pr_'+selRight);
if(lBtn) lBtn.classList.add('wrong-flash');
if(rBtn) rBtn.classList.add('wrong-flash');
setTimeout(function(){
if(lBtn){ lBtn.classList.remove('selected','wrong-flash'); }
if(rBtn){ rBtn.classList.remove('selected','wrong-flash'); }
selLeft = null; selRight = null;
}, 600);
}
}
});
return btn;
}
// Interleave: left[0], right[0], left[1], right[1]... for correct 2-col grid display
for (var i = 0; i < lefts.length; i++) {
grid.appendChild(makePairBtn(lefts[i].id, lefts[i].text, 'left'));
grid.appendChild(makePairBtn(rights[i].id, rights[i].text, 'right'));
}
}
