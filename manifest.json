function startExercise(exType){
curExType = exType;
exIdx = 0; exScore = 0;
exQueue = getModuleWords(curModuleId);
exTotal = exQueue.length;
if (exTotal === 0) { alert('Sem conteúdo disponível para este módulo neste nível.'); return; }
runNext();
}
function exHdr(){
var pct = Math.round(exIdx/exTotal*100);
return '<div class="ex-header">' +
'<button class="ex-close" id="exCloseBtn">✕</button>' +
'<div class="ex-progbar"><div class="ex-progfill" style="width:'+pct+'%"></div></div>' +
'<div class="ex-count">'+exIdx+'/'+exTotal+'</div></div>';
}
function attachClose(){
var btn = document.getElementById('exCloseBtn');
if (btn) btn.addEventListener('click', function(){ go('modules'); });
}
function runNext(){
if (exIdx >= exTotal){ showResults(); return; }
var item = exQueue[exIdx];
var isWord = item.hasOwnProperty('ph');
if (curExType === 'audio_match') buildAudioMatch(item, isWord);
else if (curExType === 'build_sentence') buildBuildSentence(item, isWord);
else if (curExType === 'listen_type') buildListenType(item, isWord);
else if (curExType === 'match_pairs') buildMatchPairs(item, isWord);
else if (curExType === 'repeat_phrase') buildRepeatPhrase(item, isWord);
}
// ── EX 1: AUDIO MATCH ──────────────────────────────────────
function buildAudioMatch(item, isWord){
var correct = item.en;
var pool = isWord ? WORDS.filter(function(x){ return x.id !== item.id; }) : ALL_SENTENCES.filter(function(x){ return x.id !== item.id; });
var wrong = pool.sort(function(){ return Math.random()-.5; }).slice(0,3).map(function(x){ return x.pt; });
var opts = [item.pt].concat(wrong).sort(function(){ return Math.random()-.5; });
var el = document.getElementById('exercise');
el.innerHTML = exHdr() +
'<div class="ex-body">' +
'<div class="ex-type-badge" style="color:#3b82f6;border-color:#3b82f640;background:#3b82f610">🔊 Combine o Áudio</div>' +
'<div class="ex-question">Ouça e toque no significado correto:</div>' +
'<div class="listen-area" style="margin-bottom:16px">' +
'<div style="display:flex;gap:8px;justify-content:center">' +
'<button class="play-btn" id="amPlay">▶ Normal</button>' +
'<button class="play-btn play-btn-slow" id="amSlow">🐢 Devagar</button>' +
'</div></div>' +
'<div class="audio-choices" id="amChoices"></div>' +
'</div>';
attachClose();
var choicesEl = document.getElementById('amChoices');
opts.forEach(function(opt){
var btn = document.createElement('button');
btn.className = 'audio-btn';
btn.textContent = opt;
btn.addEventListener('click', function(){
document.querySelectorAll('.audio-btn').forEach(function(b){ b.classList.add('locked'); });
if (opt === item.pt){
btn.classList.add('correct');
showFeedback(true, 'Correto! 🎉', '', function(){ exIdx++; exScore++; S.exDone++; S.totalEx++; S.totalCorrect++; save(); addXP(3); runNext(); });
} else {
btn.classList.add('wrong');
document.querySelectorAll('.audio-btn').forEach(function(b){ if (b.textContent === item.pt) b.classList.add('correct'); });
addError(item); showFeedback(false, 'Incorreto', '"'+correct+'" = '+item.pt, function(){ exIdx++; S.exDone++; S.totalEx++; save(); runNext(); });
}
});
choicesEl.appendChild(btn);
});
document.getElementById('amPlay').addEventListener('click', function(){ speak(correct, this); });
document.getElementById('amSlow').addEventListener('click', function(){ speak(correct, this, 0.5); });
setTimeout(function(){ speak(correct, null); }, 600);
}
// ── EX 2: BUILD SENTENCE ───────────────────────────────────
function buildBuildSentence(item, isWord){
var sentence = item.en;
var words = sentence.split(' ');
var distractors = ['the','a','is','are','not','very'].sort(function(){ return Math.random()-.5; }).slice(0,2);
var allWords = words.concat(distractors).sort(function(){ return Math.random()-.5; });
var placed = [];
var el = document.getElementById('exercise');
el.innerHTML = exHdr() +
'<div class="ex-body">' +
'<div class="ex-type-badge" style="color:#f97316;border-color:#f9731640;background:#f9731610">📝 Monte a Frase</div>' +
