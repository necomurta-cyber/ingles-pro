function buildFCDeck(){
var ul = unlocked();
var list = WORDS.filter(function(w){ return w.lv <= ul; });
if (fcCat !== 'todos') list = list.filter(function(w){ return w.cat === fcCat; });
fcDeck = list.sort(function(){ return Math.random()-.5; });
fcIdx = 0; fcR = 0; fcW = 0;
updateFC();
}
function updateFC(){
if (!fcDeck.length) return;
var c = fcDeck[fcIdx % fcDeck.length];
var card = document.getElementById('fcCard');
if (card) card.classList.remove('flip');
var w = document.getElementById('fcWord'); if(w) w.textContent = c.en;
var ph = document.getElementById('fcPh'); if(ph) ph.textContent = '/' + c.ph + '/';
var tr = document.getElementById('fcTrans'); if(tr) tr.textContent = c.pt;
var ct = document.getElementById('fcCat'); if(ct) ct.textContent = c.cat;
var cnt = document.getElementById('fcCnt'); if(cnt) cnt.textContent = ((fcIdx%fcDeck.length)+1)+'/'+fcDeck.length;
var sc = document.getElementById('fcSc'); if(sc) sc.textContent = '✅ '+fcR+' ❌ '+fcW;
var fill = document.getElementById('fcFill'); if(fill) fill.style.width = ((fcIdx%fcDeck.length)/fcDeck.length*100)+'%';
setTimeout(function(){ if(TTS && fcDeck.length) speak(c.en, null); }, 400);
}
