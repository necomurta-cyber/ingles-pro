tokyo: ['bairros','atrações','comida','cultura'],
jdm: ['carros JDM','Hakone'],
conv: ['verbos','adjetivos','perguntas','expressões','emergência']
};
var sentCats = {
airport: ['aeroporto'],
transfer: ['translado'],
hotel: ['hotel'],
tokyo: ['tokyo tour','cultura','comida'],
jdm: ['carros JDM','Hakone'],
conv: ['conversação','dia a dia','emergência','aprendizado']
};
var wCats = cats[id] || [];
var sCats = sentCats[id] || [];
var ws = WORDS.filter(function(w){ return wCats.indexOf(w.cat) >= 0 && w.lv <= unlocked(); });
var ss = ALL_SENTENCES.filter(function(s){ return sCats.indexOf(s.cat) >= 0 && s.lv <= unlocked(); });
return ws.concat(ss).sort(function(){ return Math.random() - 0.5; }).slice(0, 15);
}
