'<div class="repeat-box">' +
'<button class="play-btn" id="rpPlay" style="margin:0 auto;display:flex">▶ Ouvir a frase</button>' +
'<div class="repeat-phrase">' + text + '</div>' +
'<div class="repeat-trans">' + item.pt + '</div>' +
'</div>' +
'<div style="text-align:center;margin:16px 0">' +
'<button class="mic-btn-large" id="micRepeat">🎙️</button>' +
'<div class="mic-status" id="micStatus">Toque no microfone para falar</div>' +
'</div>' +
'<button class="submit-btn active" id="rpSkip">Pular →</button>' +
'</div>';
attachClose();
document.getElementById('rpPlay').addEventListener('click', function(){ speak(text, this); });
document.getElementById('rpSkip').addEventListener('click', function(){ exIdx++; S.exDone++; save(); runNext(); });
document.getElementById('micRepeat').addEventListener('click', function(){
var C = window.SpeechRecognition || window.webkitSpeechRecognition;
if (!C){ alert('Use Chrome para o exercício de fala.'); return; }
var btn = document.getElementById('micRepeat');
var statusEl = document.getElementById('micStatus');
var sr = new C();
sr.lang = 'en-US'; sr.continuous = false; sr.interimResults = false; sr.maxAlternatives = 3;
var gotResult = false;
sr.onresult = function(e){
gotResult = true;
var transcript = e.results[0][0].transcript;
if(btn) btn.classList.remove('rec');
if(statusEl) statusEl.textContent = 'Ouvi: "' + transcript + '"';
var sim = calcSimilarity(transcript.toLowerCase(), text.toLowerCase());
if (sim > 0.55){
showFeedback(true, 'Boa pronúncia! 🗣️', 'Você disse: "'+transcript+'"', function(){ exIdx++; exScore++; S.exDone++; S.totalEx++; S.totalCorrect++; save(); addXP(4); runNext(); });
} else {
showFeedback(false, 'Tente novamente', 'Correto: "'+text+'" | Você disse: "'+transcript+'"', function(){ exIdx++; S.exDone++; S.totalEx++; save(); runNext(); });
}
};
sr.onerror = function(e){
if(btn) btn.classList.remove('rec');
if(statusEl) statusEl.textContent = '❌ Erro: ' + e.error + '. Tente novamente.';
};
sr.onend = function(){
if(btn) btn.classList.remove('rec');
if (!gotResult && statusEl) statusEl.textContent = 'Não ouvi nada. Tente novamente.';
};
if(btn) btn.classList.add('rec');
if(statusEl) statusEl.textContent = '🎙️ Ouvindo... Fale agora!';
try { sr.start(); } catch(e) {
if(btn) btn.classList.remove('rec');
if(statusEl) statusEl.textContent = 'Erro. Tente novamente.';
}
});
setTimeout(function(){ speak(text, document.getElementById('rpPlay')); }, 600);
}
function calcSimilarity(a, b){
var longer = a.length > b.length ? a : b;
var shorter = a.length > b.length ? b : a;
if (longer.length === 0) return 1.0;
return (longer.length - levenshtein(longer, shorter)) / longer.length;
}
function levenshtein(a, b){
var m = a.length, n = b.length, dp = [];
for (var i = 0; i <= m; i++){ dp[i] = [i]; for (var j = 1; j <= n; j++) dp[i][j] = 0; }
for (var j = 0; j <= n; j++) dp[0][j] = j;
for (var i = 1; i <= m; i++) for (var j = 1; j <= n; j++){
dp[i][j] = a[i-1] === b[j-1] ? dp[i-1][j-1] : 1 + Math.min(dp[i-1][j], dp[i][j-1], dp[i-1][j-1]);
}
return dp[m][n];
}
// ─── ERROR TRACKING ───────────────────────────────────────
function addError(item){
if (!item) return;
var err = {en:item.en, pt:item.pt, cat:item.cat||'', ts:Date.now()};
S.errors = S.errors || [];
// Avoid duplicates — update timestamp if already exists
var existing = S.errors.findIndex(function(e){ return e.en === item.en; });
if (existing >= 0) { S.errors[existing].ts = Date.now(); S.errors[existing].count = (S.errors[existing].count||1)+1; }
else { err.count = 1; S.errors.push(err); }
// Keep max 100 errors
if (S.errors.length > 100) S.errors = S.errors.slice(-100);
save();
}
