function buildRepeatPhrase(item, isWord){
var text = item.en;
var el = document.getElementById('exercise');
el.innerHTML = exHdr() +
'<div class="ex-body">' +
'<div class="ex-type-badge" style="color:#10b981;border-color:#10b98140;background:#10b98110">🗣️ Repita a Frase</div>' +
